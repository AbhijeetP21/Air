# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Modern publishable key (sb_publishable_…). The legacy anon JWT also works if
# you set NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional, server-only (sb_secret_… or legacy service_role JWT). Unused in v1.
SUPABASE_SERVICE_ROLE_KEY=

# LiveKit Cloud — Project Settings (https://cloud.livekit.io)
# The URL is public (the browser connects to it). The API key + secret are
# SERVER-ONLY — they mint access tokens and must never reach the client bundle.
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Public base URL of this deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000
